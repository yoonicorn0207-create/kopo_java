package com.kopo.kangseo_0421;

public class ready {

	public static void main(String[] args) {

		String s = "Hi";
		s += "!"; // 기존 "Hi" 객체는 버려지고, "Hi!" 새 객체 생성됨
		char c = "AB".charAt(1); // 'B' (0부터 시작하는 인덱스)
		String t = " hi ".trim(); // "hi" (양쪽 공백 제거)
		byte[] bytes = "ABC".getBytes(); // 문자열을 byte 배열로 변환
		boolean same = "A".equals("a"); // false (대소문자 구분)
		
        // 출력
        System.out.println("s = " + s);
        System.out.println("c = " + c);
        System.out.println("t = " + t);

        System.out.print("bytes = ");
        for (byte b : bytes) {
            System.out.print(b + " ");
        }
        System.out.println();
        for (int i=0; i<bytes.length; i++) {
            System.out.print(bytes[i] + " ");
        }
        System.out.println();

        System.out.println("same = " + same);
        
        
        
		s += "!"; // 기존 "Hi" 객체는 버려지고, "Hi!" 새 객체 생성됨
		
		for(int i=0;i<500; i++) {
			s +=  Integer.toString(i); // 숫자를 문자로 변환???
		}
		System.out.println(s);
		
		// StringBuffer, StringBuilder
		
		// 1. StringBuilder 사용 (빠름, 동기화 X)
		StringBuilder sb = new StringBuilder("Hi");
		sb.append(" Java").append("!"); // "Hi Java!" (체이닝 가능)
		// 2. 문자열 뒤집기
		String rev = new StringBuilder("abcde").reverse().toString(); // "edcba"
		// 3. StringBuffer 사용 (Thread-Safe, 다소 느림)
		StringBuffer sbf = new StringBuffer("Safe"); sbf.append(" Mode");
		
		
	      // 출력
        System.out.println("StringBuilder 결과 = " + sb.toString());
        System.out.println("reverse 결과 = " + rev);
        System.out.println("StringBuffer 결과 = " + sbf.toString());
		
		
        //문자 1  ~ 100000을 문자열로 붙이는데, String VS StringBuffer VS StringBuilder
        //시간측정 결과 측정
        
        for(int i=0;i<=100=00;i++) {
        	s+= Integer.toString(i);
        	
        }
        
        
        
        
	}// main

}// CLASS
