		System.out.println(Arrays.toString(a));
		Integer[] b = { 6, 4, 2, 6, 1 };

		Arrays.sort(b, Collections.reverseOrder()); // 역순정렬

		System.out.println(Arrays.toString(b));

		for (int i = 0; i < a.length; i++) {
			for (int j = 0; i < a.length; j++) {
				if(a[i]>a[j]) {
					temp = a[i];
					a[i] = a[j];
					a[j] = temp;
				}//if
				
				
				
				
			}
		}

	}// main

}// CLASS
