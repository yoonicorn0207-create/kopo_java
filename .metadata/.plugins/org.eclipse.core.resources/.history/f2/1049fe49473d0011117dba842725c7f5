package com.kopo.kangseo_0421;

import java.util.ArrayList;
import java.util.List;

public class CollectionEX {

	public static void main(String[] args) {
		//방법1(강제형변환)
		ArrayList listString = new ArrayList();
		listString.add("Java");
		listString.add("Python");
		listString.add("C++"); // 순서대로 저장됨
		// 특정 인덱스 값 조회
		String langString =  (String) listString.get(0); // "Java"
		System.out.println(langString);
		// 향상된 for문 순회 (가장 권장되는 방식)
		
		//방법2(Generics)
		ArrayList<String> listGenerics = new ArrayList();
		listGenerics.add("Java");
		listGenerics.add("Python");
		listGenerics.add("C++"); // 순서대로 저장됨
		// 특정 인덱스 값 조회
		String langGenerics =  listGenerics.get(0); // "Java"
		System.out.println(langGenerics);
		// 향상된 for문 순회 (가장 권장되는 방식)
		
		
		for(int i =0; i<listGenerics.size() ;i++) {
			System.out.println(listGenerics.get(i));
		}
		
		

	}//main
}//CLASS
