package com.kopo.kangseo_0421;

public class ExceptionEx {

	public static void main(String[] args) {
		// 1. NullPointerException (NPE)
//		String s = null;
//		s.length(); // 객체가 없는 상태에서 메서드 호출 시 발생
		// 2. ArrayIndexOutOfBoundsException
//		int[] arr = {1, 2, 3};
//		int v = arr[3]; // 인덱스 범위(0~2)를 벗어난 접근 시 발생
		// 3. NumberFormatException
		try {
//			int n = Integer.parseInt("12a"); // 숫자가 아닌 문자열 변환 시 발생
			int[] arr = { 1, 2, 3 };
			int v = arr[3]; // 인덱스 범위(0~2)를 벗어난 접근 시 발생
		} catch (ArrayIndexOutOfBoundsException e) {
			System.out.println("aaa");
			System.out.println(e);
			e.printStackTrace();
		} catch (NullPointerException e) {
			System.out.println("000");
			System.out.println(e);
			e.printStackTrace();
		} catch (NumberFormatException e) {
			System.out.println("111");
			System.out.println(e); // logger
		} catch (Exception e) {
			System.out.println("222");
			System.out.println(e); // logger
		} finally {
			System.out.println("finally는 반드시 찎음");
		}

	}

}