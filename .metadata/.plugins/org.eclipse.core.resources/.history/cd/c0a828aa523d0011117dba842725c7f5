package com.kopo.kangseo_0421;

import java.util.Collections;
import java.util.TreeSet;

public class TreeSetEx {

	public static void main(String[] args) {
		TreeSet<Integer> ts = new TreeSet<>();//
		TreeSet<Integer> ts2 = new TreeSet<>(Collections.reverseOrder());
		ts.add(3); ts.add(1); ts.add(2); // 저장 시 [1, 2, 3] 정렬됨
		// 중복 데이터 추가 시 무시됨 (Set 특성)
		ts.add(3); ts.add(1); ts.add(2);
		int min = ts.first(); // 1 (최소값 반환)
		int max = ts.last(); // 3 (최대값 반환)
		for (int n : ts) {
			System.out.print(n + " "); // 출력: 1 2 3
		}

		// 🔽 역순 출력
		System.out.print("\n내림차순: ");
		for (int n : ts.descendingSet()) {
			System.out.print(n + " ");
		}
	}

}