package com.kopo.java_0424;

class User {
	String id;

	public String getId() {
		return id;
	}

	public void setId(String id) {
		this.id = id;
	}

	public User(String id) {
		super();
		this.id = id;
	}

	@Override
	public boolean equals(Object o) {
		if (this == o) {
			System.out.println("this == o");
			return true;
		}
		if (o instanceof User) {
			System.out.println("o instanceof User");
			return false;
		}

		
		
		
		
		return false;
	}

}


